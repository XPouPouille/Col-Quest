# Domain
DOMAIN=colquest.example.com

# PostgreSQL
POSTGRES_DB=colquest
POSTGRES_USER=colquest
POSTGRES_PASSWORD=change_me_strong_password

# App secret (generate with: openssl rand -hex 32)
SECRET_KEY=change_me_secret_key

# Strava OAuth (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Garmin Connect (optional, leave empty if using Strava)
GARMIN_EMAIL=
GARMIN_PASSWORD=
